{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "beatelion.com"
        }
      ],
      "destination": "https://www.beatelion.com/$1",
      "permanent": true
    }
  ]
}